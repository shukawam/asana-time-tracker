{
  "name": "@shukawam/asana-time-tracker",
  "version": "0.1.0",
  "description": "CLI to record billable hours into Asana as the single source of truth, with weekly copy-paste summaries for SFDC and Spreadsheet",
  "type": "module",
  "bin": {
    "att": "./dist/bin/att.js"
  },
  "files": [
    "dist",
    "skills",
    "img",
    "README.md",
    "README_ja.md",
    "LICENSE"
  ],
  "scripts": {
    "att": "tsx src/bin/att.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "asana",
    "time-tracking",
    "cli"
  ],
  "author": "Shuhei Kawamura",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shukawam/asana-time-tracker.git"
  },
  "homepage": "https://github.com/shukawam/asana-time-tracker#readme",
  "bugs": {
    "url": "https://github.com/shukawam/asana-time-tracker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.0",
    "asana": "^3.0.13",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
